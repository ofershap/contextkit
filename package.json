{
  "name": "contextkit-ai",
  "version": "0.1.0",
  "description": "Intelligent context management for AI coding agents. Load, lint, measure, and sync rules across Cursor, Claude Code, Copilot, and any AI tool.",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "contextkit": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "context",
    "ai",
    "agent",
    "cursor",
    "claude",
    "copilot",
    "rules",
    "cursorrules",
    "agents-md",
    "context-engineering",
    "mcp",
    "ai-coding",
    "lint",
    "sync",
    "token-budget",
    "llm",
    "windsurf",
    "cline"
  ],
  "author": "Ofer Shapira",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ofershap/contextkit.git"
  },
  "bugs": {
    "url": "https://github.com/ofershap/contextkit/issues"
  },
  "homepage": "https://github.com/ofershap/contextkit#readme",
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.21.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.3",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.25.0",
    "vitest": "^3.0.7"
  }
}
